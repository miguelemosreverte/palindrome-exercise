flowchart TB
    subgraph product[Product Experience]
        landing[Landing]
        authUi[Auth]
        billing[Billing / Usage]
        demoUi[Free Demo]
        chatUi[Paid Chat]
        backoffice[Admin Back Office]
    end

    subgraph billingCore[Billing & Access Core]
        checkout[Checkout Preference]
        webhook[Payment Webhook]
        entitlement[Quota / Access Control]
        usage[Usage Metering]
    end

    subgraph identity[Identity Core]
        login[Login]
        register[Register]
        session[Signed Auth Token]
        adminRole[Admin Role]
    end

    subgraph storage[Persistence]
        users[Users]
        payments[Payments]
        usageStore[Usage Events + Summaries]
        chats[Chats]
        anon[Anonymous Demo Sessions]
    end

    subgraph integrations[External Integrations]
        mercado[Mercado Pago]
        provider[LLM Provider]
    end

    landing --> checkout
    checkout --> mercado
    mercado --> webhook
    webhook --> payments
    webhook --> entitlement

    authUi --> login
    authUi --> register
    login --> session
    register --> session
    session --> adminRole
    login --> users
    register --> users

    demoUi --> entitlement
    demoUi --> usage
    demoUi --> anon
    demoUi --> provider

    chatUi --> entitlement
    chatUi --> usage
    chatUi --> chats
    chatUi --> provider

    billing --> payments
    billing --> usageStore
    billing --> entitlement

    backoffice --> users
    backoffice --> payments
    backoffice --> usageStore
    backoffice --> chats
    backoffice --> anon
